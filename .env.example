# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pickle_store

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=<min-32-char-random-hex>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<different-min-32-char-random-hex>
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (Nodemailer / Gmail App Password) ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Pickle & Co. <your@gmail.com>"

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── NimbusPost ────────────────────────────────────────────────────────────────
NIMBUSPOST_EMAIL=your@email.com
NIMBUSPOST_PASSWORD=your_nimbuspost_password
NIMBUSPOST_COURIER_ID=244
DEV_MODE=true
# Pickup / Warehouse details (must match your NimbusPost account warehouse)
NIMBUSPOST_WAREHOUSE_NAME=Primary
NIMBUSPOST_PICKUP_NAME=Pickle And Co
NIMBUSPOST_PICKUP_ADDRESS=2-13,Kolanukonda,Tadepalli
NIMBUSPOST_PICKUP_CITY=Guntur
NIMBUSPOST_PICKUP_STATE=Andhra Pradesh
NIMBUSPOST_PICKUP_PINCODE=522502
NIMBUSPOST_PICKUP_PHONE=9052355733

# ── Frontend (REQUIRED for CORS and email reset links) ───────────────────────
CLIENT_URL=http://localhost:3000
